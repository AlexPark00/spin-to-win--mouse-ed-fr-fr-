[sub_resource type="GDScript" id="GDScript_ybxip"]
script/source = "extends Node2D

func play_animation() -> void:
	var tween = get_tree().create_tween();
	tween.tween_property($Sprite2D, \"frame\", 3, 0.5);
	await tween.finished;
"

